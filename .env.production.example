# ============================================================================
#  Frontend Next.js — PRODUCTION (export statique / SPA)
#  Deploiement : https://2mcrafters.com/location
#  Backend     : https://2mcrafters.com/location/backend
# ============================================================================
#
#  Copiez ce fichier en .env.production puis lancez le build statique :
#     NEXT_OUTPUT=export npm run build
#  Le resultat se trouve dans Dashboard/out (a servir sous /location).
#
# ----------------------------------------------------------------------------

# Active l'export statique (SPA, dossier ./out). Requis pour la prod statique.
NEXT_OUTPUT=export

# Sous-chemin ou l'app est servie (sans slash final).
NEXT_PUBLIC_BASE_PATH=/location

# URL de base de l'API Laravel, appelee DIRECTEMENT par le navigateur (SPA).
# En export statique il n'y a plus de proxy /api Next : pointez vers Laravel.
# Chemin relatif recommande (meme domaine -> pas de souci CORS de domaine) :
NEXT_PUBLIC_API_BASE_URL=/location/backend/api

# (Optionnel) URL absolue si le backend est sur un autre domaine/host.
# Dans ce cas, activez CORS cote Laravel (voir backend/.env.production.example).
# NEXT_PUBLIC_API_BASE_URL=https://2mcrafters.com/location/backend/api

# API_BASE_URL servait au proxy /api cote serveur Node : INUTILE en export
# statique (aucun serveur Node). Laisse vide / non defini.
# API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL= https://2mcrafters.com/location/backend/api
API_BASE_URL= https://2mcrafters.com/location/backend/api

